      "Bash(python app.py)",
      "Bash(curl -s -X POST http://localhost:5000/admin/reset-db)",
      "Bash(python -m json.tool)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" -X POST http://localhost:5000/admin/reset-db)",
      "Bash(curl -s -X POST http://localhost:5000/admin/query -H 'Content-Type: application/json' -d '{\"sql\":\"SELECT * FROM usuarios\"}')",
